{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Datadog Agent image references",
      "managerFilePatterns": [
        "**/*.yaml",
        "**/*.yml",
        "**/*.tf",
        "**/*.json",
        "**/*.sh",
        "**/Dockerfile*"
      ],
      "matchStrings": [
        "(?<depName>public\\.ecr\\.aws/datadog/agent|docker\\.io/datadog/agent|index\\.docker\\.io/datadog/agent|datadog/agent|docker\\.mirror\\.hashicorp\\.services/datadog/agent):(?<currentValue>[A-Za-z0-9._-]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "AWS Fluent Bit image references",
      "managerFilePatterns": [
        "**/*.yaml",
        "**/*.yml",
        "**/*.tf",
        "**/*.json",
        "**/*.sh",
        "**/Dockerfile*"
      ],
      "matchStrings": [
        "(?<depName>public\\.ecr\\.aws/aws-observability/aws-for-fluent-bit|docker\\.io/amazon/aws-for-fluent-bit|index\\.docker\\.io/amazon/aws-for-fluent-bit|amazon/aws-for-fluent-bit|docker\\.mirror\\.hashicorp\\.services/amazon/aws-for-fluent-bit):(?<currentValue>[A-Za-z0-9._-]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "public.ecr.aws/datadog/agent",
        "docker.io/datadog/agent",
        "index.docker.io/datadog/agent",
        "datadog/agent",
        "docker.mirror.hashicorp.services/datadog/agent"
      ],
      "allowedVersions": "/^7\\./",
      "groupName": "Datadog Agent",
      "labels": [
        "dependencies",
        "security"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "public.ecr.aws/aws-observability/aws-for-fluent-bit",
        "docker.io/amazon/aws-for-fluent-bit",
        "index.docker.io/amazon/aws-for-fluent-bit",
        "amazon/aws-for-fluent-bit",
        "docker.mirror.hashicorp.services/amazon/aws-for-fluent-bit"
      ],
      "allowedVersions": "!/\\.\\d{8}$/",
      "groupName": "AWS Fluent Bit",
      "labels": [
        "dependencies",
        "security"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability"
    ]
  }
}
