{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "includePaths": ["**/*"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Datadog Agent image references",
      "managerFilePatterns": [
        "\\.ya?ml$",
        "\\.tf$",
        "\\.json$",
        "\\.sh$",
        "Dockerfile"
      ],
      "matchStrings": [
        "(?<depName>public\\.ecr\\.aws/datadog/agent):(?<currentValue>[A-Za-z0-9._-]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "AWS Fluent Bit image references",
      "managerFilePatterns": [
        "\\.ya?ml$",
        "\\.tf$",
        "\\.json$",
        "\\.sh$",
        "Dockerfile"
      ],
      "matchStrings": [
        "(?<depName>public\\.ecr\\.aws/aws-observability/aws-for-fluent-bit):(?<currentValue>[A-Za-z0-9._-]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "public.ecr.aws/datadog/agent"
      ],
      "allowedVersions": "/^7\\./",
      "groupName": "Datadog Agent",
      "labels": [
        "dependencies",
        "security"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "public.ecr.aws/aws-observability/aws-for-fluent-bit"
      ],
      "groupName": "AWS Fluent Bit",
      "labels": [
        "dependencies",
        "security"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "vulnerability"
    ]
  }
}
